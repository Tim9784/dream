[Unit]
Description=Seabattle online game (gunicorn backend)
After=network.target redis-server.service

[Service]
WorkingDirectory=/opt/minecraft-panel
Environment=PANEL_CONFIG=/opt/minecraft-panel/config.json
ExecStart=/opt/minecraft-panel/venv/bin/gunicorn -b 127.0.0.1:18090 -w 2 --timeout 30 --max-requests 1000 --max-requests-jitter 100 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
